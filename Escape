-- PROTECTED FILTER (Dit mag NOOIT weg)
local PROTECTED = {"Craft","Station","Portal","Upgrade","Shop","Spawn","Base","Vloer","Floor","HumanoidRootPart"}
local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED) do
        if name:find(word:lower()) then return true end
    end
    return false
end

-- ==========================================
-- HARDCORE DESTROY FUNCTION (Ontlast de GPU maximaal)
-- ==========================================
local function hardcoreDestroy(obj)
    pcall(function()
        if obj == char or isProtected(obj) then return end
        
        -- Als het een speler is, laat alleen de RootPart staan tegen crashes
        if obj:IsA("Model") and Players:GetPlayerFromCharacter(obj) then
            for _, part in ipairs(obj:GetChildren()) do
                if part.Name ~= "HumanoidRootPart" then part:Destroy() end
            end
            return
        end
        
        obj:Destroy()
    end)
end

-- Bestaande mappen en objecten in workspace hard opschonen
local BasesFolder = workspace:FindFirstChild("Bases")
local myPlot = nil

-- Zoek eerst je eigen plot zodat we die niet slopen
if BasesFolder and root then
    local minDist = math.huge
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local ref = plot:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            local dist = (ref.Position - root.Position).Magnitude
            if dist < minDist then
                minDist = dist
                myPlot = plot
            end
        end
    end
end

-- Gooi alle andere plots en workspace rommel direct in de prullenbak
for _, obj in ipairs(workspace:GetChildren()) do
    if obj == char or obj == workspace.Terrain or obj:IsA("Camera") then continue end
    
    if obj == BasesFolder then
        for _, plot in ipairs(BasesFolder:GetChildren()) do
            if plot ~= myPlot then
                plot:Destroy() -- Andere plots compleet wegvagen!
            end
        end
    else
        hardcoreDestroy(obj)
    end
end

-- Live spawn-blocker: Alles wat nieuw binnenkomt meteen DESTROYEN
workspace.ChildAdded:Connect(function(obj)
    task.defer(function()
        hardcoreDestroy(obj)
    end)
end)

if BasesFolder then
    BasesFolder.ChildAdded:Connect(function(obj)
        task.defer(function()
            if obj ~= myPlot then obj:Destroy() end
        end)
    end)
end

print("🔥 GPU MAXIMAAL ONTLAST: Alles vernietigd!")

