-- =========================================================================
-- ROLL COUNTER (GEBRUIKT OBSERVE PATROON)
-- =========================================================================
local function setupRollObserver()
    local potentialKeys = {"Rolls", "TotalRolls", "Stats"}
    
    for _, key in ipairs(potentialKeys) do
        task.spawn(function()
            pcall(function()
                ClientGlobals.PlayerData:Observe({key}, function(val)
                    if type(val) == "number" then
                        _G.MzDRolls = val
                    elseif type(val) == "table" and val.Rolls then
                        _G.MzDRolls = val.Rolls
                    end
                end)
            end)
        end)
    end
end
setupRollObserver()

