local startTime = tick()
local UPGRADES = {"RollSpeed","Luck","InfinityLuck","EternalLuck","TraitLuck"}

task.spawn(function()
    while gui and gui.Parent do
        -- Update Counters
        timeLbl.Text = "⏱ " .. os.date("!%H:%M:%S", tick() - startTime)
        rollsLbl.Text = "🎲 Rolls: " .. _G.MzDRolls
        normalLbl.Text = "Normal: " .. getDiceCount("Normal")
        megaLbl.Text = "MegaRainbow: " .. getDiceCount("MegaRainbow")
        
        -- Upgrades check
        local allMax = true
        for _, name in ipairs(UPGRADES) do
            if not isUpgradeMaxed(name) then allMax = false break end
        end
        upgradeLbl.Text = allMax and "UPGRADES: ✅ ALL MAX" or "UPGRADES: 🔄 Bezig..."
        
        -- Buffs (Observer check)
        local activeBuffs = getData().DiceBuffs
        buffLbl.Text = activeBuffs and "Buffs: Actief" or "Buffs: Geen"
        
        task.wait(0.5)
    end
end)

