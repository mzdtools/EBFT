-- ITEM TRACKER
local diceRolls = 0
local infinityCount = 0
local eternalCount = 0
local trackedItems = {}

local backpack = LocalPlayer:WaitForChild("Backpack", 15)

if backpack then
    for _, item in ipairs(backpack:GetChildren()) do
        if not trackedItems[item] then
            trackedItems[item] = true
            diceRolls = diceRolls + 1
            local itemName = item.Name:lower()
            if string.find(itemName, "infinity") then
                infinityCount = infinityCount + 1
            elseif string.find(itemName, "eternal") then
                eternalCount = eternalCount + 1
            end
        end
    end
    
    DiceLabel.Text = diceRolls .. " number of dice rolls"
    InfinityLabel.Text = infinityCount .. " number of Infinity counts?"
    EternalLabel.Text = eternalCount .. " number of Eternal counts?"
    
    backpack.ChildAdded:Connect(function(item)
        if trackedItems[item] then return end
        trackedItems[item] = true
        diceRolls = diceRolls + 1
        DiceLabel.Text = diceRolls .. " number of dice rolls"
        local itemName = item.Name:lower()
        if string.find(itemName, "infinity") then
            infinityCount = infinityCount + 1
            InfinityLabel.Text = infinityCount .. " number of Infinity counts?"
        elseif string.find(itemName, "eternal") then
            eternalCount = eternalCount + 1
            EternalLabel.Text = eternalCount .. " number of Eternal counts?"
            task.spawn(function()
                for i = 1, 3 do
                    EternalLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
                    task.wait(0.15)
                    EternalLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
                    task.wait(0.15)
                end
            end)
        end
    end)
    
    backpack.ChildRemoved:Connect(function(item)
        trackedItems[item] = nil
    end)
end

-- AUTO UPGRADE
local upgradeActive = true
local RF = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Remotes"):WaitForChild("Networking"):WaitForChild("RF/RNGUpgradePurchase")

local function safePurchase(name)
    local s, r = pcall(function() return RF:InvokeServer(name) end)
    if not s then return false end
    return r ~= false and r ~= nil
end

local function maxOutUpgrade(name)
    while upgradeActive do
        if not safePurchase(name) then break end
        task.wait(0.4)
    end
end

task.spawn(function()
    task.wait(3)
    while upgradeActive do
        maxOutUpgrade("RollSpeed")
        maxOutUpgrade("Luck")
        local inf_done, ete_done = false, false
        while not (inf_done and ete_done) and upgradeActive do
            if not inf_done then
                if not safePurchase("InfinityLuck") then inf_done = true else task.wait(0.4) end
            end
            if not ete_done then
                if not safePurchase("EternalLuck") then ete_done = true else task.wait(0.4) end
            end
        end
        maxOutUpgrade("TraitLuck")
        task.wait(1800)
    end
end)

game:BindToClose(function() upgradeActive = false end)
