local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui        = game:GetService("StarterGui")
local lp                = Players.LocalPlayer

-- Stap 1: Herstel volledige PlayerGui vanuit StarterGui
print("🔄 PlayerGui herstellen...")
for _, item in ipairs(StarterGui:GetChildren()) do
    local existing = lp.PlayerGui:FindFirstChild(item.Name)
    if existing then existing:Destroy() end
    local clone = item:Clone()
    clone.Parent = lp.PlayerGui
    print("✅ Hersteld: " .. item.Name)
end

task.wait(1)

-- Stap 2: CoreGui aan
pcall(function()
    StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
end)

-- Stap 3: Alle ScreenGuis enablen
for _, gui in ipairs(lp.PlayerGui:GetChildren()) do
    if gui:IsA("ScreenGui") then
        gui.Enabled = true
    end
end

task.wait(0.5)

-- Stap 4: MenuManager → trade scherm openen
pcall(function()
    local MenuManager = require(ReplicatedStorage.Client.Modules.MenuManager)
    -- Probeer alle mogelijke namen
    for _, name in ipairs({"Trade", "TradeNegotiation", "Trading", "TradingUI", "ActiveNegotiation"}) do
        pcall(function() MenuManager.open(name) end)
    end
    print("✅ MenuManager aangeroepen")
end)

task.wait(0.5)

-- Stap 5: ActiveNegotiation controleren en UI forceren
pcall(function()
    local ClientGlobals = require(ReplicatedStorage.Client.Modules.ClientGlobals)
    local neg = ClientGlobals.ActiveNegotiation and ClientGlobals.ActiveNegotiation.Data
    if neg then
        print("✅ ActiveNegotiation actief — trade UI forceren")
        -- Zoek en toon trade-gerelateerde UI
        for _, gui in ipairs(lp.PlayerGui:GetChildren()) do
            if gui.Name:lower():find("trade") or gui.Name:lower():find("negot") then
                gui.Enabled = true
                print("✅ Gevonden: " .. gui.Name)
            end
        end
        -- Probeer Menus.Trade direct
        local menus = lp.PlayerGui:FindFirstChild("Menus")
        if menus then
            local trade = menus:FindFirstChild("Trade", true)
            if trade then
                trade.Visible = true
                print("✅ Trade menu zichtbaar gemaakt")
            end
        end
    else
        print("⚠️ Geen actieve trade onderhandeling gevonden")
    end
end)

-- Stap 6: Camera normaal
workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
print("✅ Klaar! Trade scherm zou nu zichtbaar moeten zijn.")


