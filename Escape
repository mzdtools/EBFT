                usedLbl.TextColor3 = Color3.fromRGB(255, 140, 0)
            else
                usedLbl.Text = "🎯 STATUS: 💤 Standby. Wachten op Dice777Event..."
                usedLbl.TextColor3 = Color3.fromRGB(140, 200, 255)
            end
        end)
        task.wait(1)
    end
end)

