-- =========================================================================
-- DATA VERWERKING & FILTERS
-- =========================================================================
local function getData() return ClientGlobals.PlayerData and ClientGlobals.PlayerData.Data end

local function getDiceCount(diceType)
    local data = getData()
    if not data or not data.Inventory then return 0 end
    local count = 0
    for _, item in pairs(data.Inventory) do
        if item.sub and item.sub.diceType == diceType then
            count = count + (type(item.sub.amount) == "number" and item.sub.amount or 1)
        end
    end
    return count
end

local function getUpgradeLevel(name) local data = getData() return (data and data.RNGUpgrades and data.RNGUpgrades[name]) or 0 end
local function isUpgradeMaxed(name) local cfg = RNGConfig.Upgrades[name] return cfg and getUpgradeLevel(name) >= cfg.MaxLevel end

local function countCollectedRarity(targetRarity)
    local data = getData()
    if not data or not data.CollectedBrainrots then return 0 end
    local count = 0
    for _, brainrots in pairs(data.CollectedBrainrots) do
        for name, _ in pairs(brainrots) do
            if BrainrotModule.BrainrotRarities[name] == targetRarity then count = count + 1 end
        end
    end
    return count
end

local function getActiveDiceBuffs()
    local data = getData()
    if not data or not data.DiceBuffs then return "geen" end
    local parts = {}
    for diceType, buffData in pairs(data.DiceBuffs) do
        if type(buffData) == "table" and type(buffData.rollsRemaining) == "number" and buffData.rollsRemaining > 0 then
            table.insert(parts, diceType .. " x" .. buffData.rollsRemaining)
        end
    end
    return #parts > 0 and table.concat(parts, " ") or "geen"
end

local function getActiveEvents()
    local parts = {}
    local activeData = ClientGlobals.ActiveEvents and ClientGlobals.ActiveEvents.Data
    if activeData then
        local short = { RollFrenzyEvent = "RollFrenzy", Dice777Event = "777", Jackpot = "Jackpot" }
        for eventName, endTime in pairs(activeData) do
            if type(endTime) == "number" then
                local t = math.floor(endTime - workspace:GetServerTimeNow())
                if t > 0 then table.insert(parts, (short[eventName] or eventName) .. " " .. string.format("%d:%02d", math.floor(t/60), t%60)) end
            end
        end
    end
    return #parts > 0 and table.concat(parts, " | ") or "geen"
end

