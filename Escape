                end
                buffLbl.Text = #parts > 0 and table.concat(parts, "  ") or "geen"
            else
                buffLbl.Text = "geen"
            end

            if ClientGlobals and ClientGlobals.ActiveEvents and ClientGlobals.ActiveEvents.Data then
