-- DELTA SCANNER (roll tracker)
-- =========================================================================
local function scanDataTable()
    local data = ClientGlobals.PlayerData and ClientGlobals.PlayerData.Data
    if not data then return end
    local function rScan(t, path)
        for k, v in pairs(t) do
            local p = path .. "." .. tostring(k)
            if type(v) == "number" then
                if previousNumbers[p] and v > previousNumbers[p] then
                    local diff = v - previousNumbers[p]
                    if string.find(string.lower(tostring(k)), "roll")
                    or string.find(string.lower(tostring(k)), "spin")
                    or diff == 1 then
                        _G.MzDSessionRolls = _G.MzDSessionRolls + 1
                    end
                end
                previousNumbers[p] = v
            elseif type(v) == "table" and k ~= "Inventory" then
                rScan(v, p)
            end
        end
    end
    rScan(data, "Data")
end

task.spawn(function()
    while task.wait(0.2) do pcall(scanDataTable) end
end)

