local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local LocalPlayer = Players.LocalPlayer

local PROTECTED_KEYWORDS = {
    "craft", "station", "portal", "upgrade", "shop", 
    "spawn", "gui", "camera", "script", "remote",
    "bindable", "sound", "music", "ambient"
}

local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED_KEYWORDS) do
        if name:find(word) then return true end
    end
    return false
end

local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

-- Vind jouw plot
local myPlot = nil
local Bases = workspace:FindFirstChild("Bases")
if Bases then
    myPlot = Bases:FindFirstChild(LocalPlayer.Name)
    -- Fallback: zoek op UserId
    if not myPlot then
        myPlot = Bases:FindFirstChild(tostring(LocalPlayer.UserId))
    end
    -- Fallback: zoek op Owner value
    if not myPlot then
        for _, base in ipairs(Bases:GetChildren()) do
            local owner = base:FindFirstChild("Owner")
                       or base:FindFirstChild("PlayerName")
                       or base:FindFirstChild("UserId")
            if owner and (owner.Value == LocalPlayer.Name 
                or owner.Value == tostring(LocalPlayer.UserId)) then
                myPlot = base
                break
            end
        end
    end
end

-- Lighting platleggen
pcall(function()
    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.GlobalShadows = false
    Lighting.Brightness = 0
    Lighting.ClockTime = 0
    Lighting.OutdoorAmbient = Color3.new(0,0,0)
    Lighting.Ambient = Color3.new(0,0,0)
    Lighting.FogEnd = 100000
    Lighting.FogStart = 100000
end)

for _, e in ipairs(Lighting:GetChildren()) do
    pcall(function()
        if e:IsA("PostEffect") then e.Enabled = false end
    end)
end

-- Terrain platleggen
pcall(function()
    workspace.Terrain.WaterWaveSize = 0
    workspace.Terrain.WaterWaveSpeed = 0
    workspace.Terrain.WaterReflectance = 0
    workspace.Terrain.WaterTransparency = 1
    workspace.Terrain.Decoration = false
end)

-- Workspace strippen
for _, obj in ipairs(workspace:GetChildren()) do
    if obj == char then continue end
    if obj == myPlot then continue end
    if obj:IsA("Terrain") then continue end
    if obj:IsA("Camera") then continue end
    if isProtected(obj) then continue end

    pcall(function()
        if obj.Name == "Bases" and Bases then
            -- Andere plots destroyen, eigen plot bewaren
            for _, plot in ipairs(Bases:GetChildren()) do
                if plot ~= myPlot then
                    plot:Destroy()
                end
            end
        else
            obj:Destroy()
        end
    end)
end

-- Live strippen van nieuwe objecten
workspace.ChildAdded:Connect(function(obj)
    if obj == char then return end
    if obj == myPlot then return end
    if obj:IsA("Terrain") then return end
    if obj:IsA("Camera") then return end
    if isProtected(obj) then return end

    task.defer(function()
        pcall(function() obj:Destroy() end)
    end)
end)

-- Character respawn
LocalPlayer.CharacterAdded:Connect(function(newChar)
    char = newChar
end)

print("✅ Gestript!")
