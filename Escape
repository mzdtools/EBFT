-- =========================================================================
-- DYNAMIC DELTA SCANNER (Jouw werkende live-tracker engine)
-- =========================================================================
local function scanDataTable()
    local data = ClientGlobals.PlayerData and ClientGlobals.PlayerData.Data
    if not data then return end
    
    local function rScan(t, currentPath)
        for k, v in pairs(t) do
            local path = currentPath .. "." .. tostring(k)
            if type(v) == "number" then
                if previousNumbers[path] and v > previousNumbers[path] then
                    local diff = v - previousNumbers[path]
                    if string.find(string.lower(tostring(k)), "roll") or string.find(string.lower(tostring(k)), "spin") or diff == 1 then
                        _G.MzDSessionRolls = _G.MzDSessionRolls + 1
                    end
                end
                previousNumbers[path] = v
            elseif type(v) == "table" and k ~= "Inventory" then
                rScan(v, path)
            end
        end
    end
    rScan(data, "Data")
end

task.spawn(function()
    while task.wait(0.2) do
        pcall(scanDataTable)
    end
end)

