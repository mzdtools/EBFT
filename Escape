-- ==========================================
-- TOTAL HARDCORE PERFORMANCE & CLEANER SCRIPT
-- ==========================================
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local BasesFolder = workspace:FindFirstChild("Bases")

-- Character tracking om crashes/resets te voorkomen
local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")

LocalPlayer.CharacterAdded:Connect(function(newChar)
    char = newChar
    root = newChar:WaitForChild("HumanoidRootPart")
end)

-- Veilig wachten tot de game en jouw plot goed zijn ingeladen
local LOAD_WAIT = 4
print("⏳ Wachten op laden... (" .. LOAD_WAIT .. "s)")
task.wait(LOAD_WAIT)

BasesFolder = workspace:WaitForChild("Bases", 20)
char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
root = char:WaitForChild("HumanoidRootPart")

-- ==========================================
-- 1. JOUW PLOT DETECTEREN
-- ==========================================
local myPlot = nil
if BasesFolder and root then
    local minDistance = math.huge
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local ref = plot:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            local dist = (ref.Position - root.Position).Magnitude
            if dist < minDistance then
                minDistance = dist
                myPlot = plot
            end
        end
    end
end

print(myPlot and "✅ Jouw plot gedetecteerd: " .. myPlot.Name or "⚠️ Geen eigen plot gevonden!")

-- Filters voor belangrijke game-objecten
local PROTECTED_KEYWORDS = {"Craft", "Station", "Portal", "Upgrade", "Shop", "Spawn", "Base"}
local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED_KEYWORDS) do
        if name:find(word:lower()) then return true end
    end
    return false
end

-- ==========================================
-- 2. LIGHTING & RENDERING COMPRESSIE
-- ==========================================
pcall(function()
    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 150         -- Alles buiten 150 studs stopt met renderen
    Lighting.FogStart = 100
    Lighting.FogColor = Color3.fromRGB(0, 0, 0)
end)

for _, e in ipairs(Lighting:GetChildren()) do
    pcall(function()
        if e:IsA("PostEffect") then e.Enabled = false end
    end)
end

pcall(function()
    Workspace.Terrain.WaterWaveSize = 0
    Workspace.Terrain.WaterWaveSpeed = 0
    Workspace.Terrain.Decoration = false
end)

-- ==========================================
-- 3. HET SLIMME SCHOONMAAKWERK (Clean & Strip)
-- ==========================================
local function cleanObject(obj, isOwnPlot)
    pcall(function()
        -- Verwijder 2D lag (Plaatjes, tekst, GUI's)
        if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") then
            obj:Destroy()
        
        -- Verwijder zware 3D Models en effecten (Brainrot meshes, deeltjes)
        elseif obj:IsA("SpecialMesh") or obj:IsA("CharacterMesh") or obj:IsA("Accessory") 
            or obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Fire") 
            or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj:Destroy()
            
        -- MeshParts onzichtbaar maken om fouten te voorkomen
        elseif obj:IsA("MeshPart") then
            obj.Transparency = 1
            obj.CanCollide = false
            obj.CastShadow = false
            
        -- Neppe NPC's/Beelden slopen, echte spelers met rust laten
        elseif obj:IsA("Humanoid") then
            local parentModel = obj.Parent
            if parentModel and parentModel:IsA("Model") and not Players:GetPlayerFromCharacter(parentModel) then
                parentModel:Destroy()
            end
            
        -- Geluiden dempen
        elseif obj:IsA("Sound") then
            obj.Volume = 0

        -- VLOER EN BLOKKEN OPTIMALISEREN (Dit beschermt jouw kleine blokjes)
        elseif obj:IsA("BasePart") then
            obj.CastShadow = false
            obj.Material = Enum.Material.SmoothPlastic -- Forceer kaal plastic (0% GPU lag)
            
            if not isOwnPlot then
                -- Als het andermans base is, mag alles onzichtbaar en collision uit
                obj.Transparency = 1
                obj.CanCollide = false
                obj.CanTouch = false
                obj.CanQuery = false
            else
                -- Dit is JOUW base: als een muur extreem hoog/groot is, verberg hem. Vloer blijft staan.
                if obj.Size.Y > 15 and not isProtected(obj) then
                    obj.Transparency = 1
                    obj.CanCollide = false
                end
            end
        end
    end)
end

-- Bestaande mappen opschonen
if BasesFolder then
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local isOwnPlot = (plot == myPlot)
        
        -- Maak direct schoon
        for _, obj in ipairs(plot:GetDescendants()) do
            cleanObject(obj, isOwnPlot)
        end
        
        -- Blijf live binnenkomende objecten in de bases scannen en cleanen
        plot.DescendantAdded:Connect(function(desc)
            cleanObject(desc, isOwnPlot)
        end)
    end
end

-- ==========================================
-- 4. WORKSPACE & LOBBY VEILIG OPTIMALISEREN
-- ==========================================
for _, obj in ipairs(Workspace:GetChildren()) do
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") or isProtected(obj) then continue end
    
    pcall(function()
        -- Grote map-funderingen/Baseplates NIET slopen om vallen te voorkomen, wel onzichtbaar maken
        if obj:IsA("BasePart") then
            obj.Transparency = 1
            obj.CastShadow = false
            obj.Material = Enum.Material.SmoothPlastic
        end
        for _, desc in ipairs(obj:GetDescendants()) do
            cleanObject(desc, false)
        end
    end)
end

-- ==========================================
-- 5. ANIMATIES STOPPEN & LIVE WORKSPACE FILTER
-- ==========================================
local function stopAnimations(character)
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("Animator") then
            for _, track in ipairs(obj:GetPlayingAnimationTracks()) do pcall(function() track:Stop() end) end
        end
    end
end

-- Stop animaties van spelers die al binnen zijn
for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer and player.Character then stopAnimations(player.Character) end
end

-- Stop animaties van nieuwe spelers
Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(otherChar)
        task.wait(1)
        stopAnimations(otherChar)
    end)
end)

-- Live workspace tracker (Houdt nieuwe drops/spawns schoon zonder de map te breken)
Workspace.ChildAdded:Connect(function(obj)
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") or isProtected(obj) then return end
    task.defer(function()
        pcall(function() 
            if obj:IsA("BasePart") then
                if obj.Size.X > 200 or obj.Size.Z > 200 then
                    obj.Transparency = 1 -- Grote spawns/vloeren alleen onzichtbaar maken
                    obj.Material = Enum.Material.SmoothPlastic
                else
                    obj:Destroy() -- Kleine losse troep direct vernietigen
                end
            else
                for _, desc in ipairs(obj:GetDescendants()) do cleanObject(desc, false) end
            end
        end)
    end)
end)

print("🚀 TOTAL BOOSTER GEACTIVEERD: Geen brainrot, geen decals, stabiele vloer en maximale FPS!")
