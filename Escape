-- ==========================================
-- STANDALONE BRAINROT & DECAL CLEANER
-- ==========================================
local BasesFolder = workspace:FindFirstChild("Bases")

if not BasesFolder then
    warn("⚠️ Map 'Bases' niet gevonden! Zorg dat de map goed is ingeladen.")
    return
end

print("🧹 Cleaner Gestart: Brainrot & Decals verwijderen...")

for _, plot in ipairs(BasesFolder:GetChildren()) do
    for _, obj in ipairs(plot:GetDescendants()) do
        pcall(function()
            -- 1. Verwijder alle plaatjes, gezichten en zwevende tekst
            if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") then
                obj:Destroy()
            
            -- 2. Verwijder 3D Meshes (Dit zijn de complexe brainrot models)
            elseif obj:IsA("SpecialMesh") or obj:IsA("CharacterMesh") or obj:IsA("Accessory") then
                obj:Destroy()
                
            -- 3. MeshParts zijn vaak objecten/beelden. We maken ze visueel leeg.
            elseif obj:IsA("MeshPart") then
                obj.Transparency = 1
                obj.CanCollide = false
                obj.CastShadow = false
                
            -- 4. Verwijder neppe characters/NPC's die in bases staan (zoals die guy op je screenshot)
            elseif obj:IsA("Humanoid") then
                local npcModel = obj.Parent
                -- Check of het NIET een echte speler is
                if npcModel and npcModel:IsA("Model") and not game.Players:GetPlayerFromCharacter(npcModel) then
                    npcModel:Destroy()
                end
                
            -- 5. Verwijder alle laggy effecten
            elseif obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                obj:Destroy()
                
            -- 6. Bescherm de vloer (Normale Parts), maar optimaliseer ze
            elseif obj:IsA("BasePart") then
                obj.CastShadow = false
                
                -- Als een normaal blok bizar lang/hoog is (zoals een grote muur), verberg hem dan ook
                if obj.Size.Y > 15 then
                    obj.Transparency = 1
                    obj.CanCollide = false
                end
            end
        end)
    end
end

print("✅ Succes! Alle brainrot, decals en meshes zijn gestript. Vloer is intact.")
