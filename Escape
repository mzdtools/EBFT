-- =========================================================================
-- MAP & PLOT CLEANER (Verwijrederd alle onnodige objecten en lag)
-- =========================================================================
local PROTECTED = {"Craft", "Station", "Portal", "Upgrade", "Shop", "Spawn", "Base"}
local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED) do
        if name:find(word:lower()) then return true end
    end
    return false
end

local BasesFolder = workspace:FindFirstChild("Bases")
local myPlot = nil

if BasesFolder and root then
    local minDist = math.huge
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local ref = plot:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            local dist = (ref.Position - root.Position).Magnitude
            if dist < minDist then
                minDist = dist
                myPlot = plot
            end
        end
    end
end

-- Eigen plot opschonen (alleen functionele dingen overhouden)
if myPlot then
    for _, obj in ipairs(myPlot:GetDescendants()) do
        pcall(function()
            if isProtected(obj) then
                if obj:IsA("BasePart") then obj.CastShadow = false end
            elseif obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SpecialMesh") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") then
                obj:Destroy()
            elseif obj:IsA("BasePart") then
                obj.CastShadow = false
                obj.Material = Enum.Material.SmoothPlastic
            end
        end)
    end
end

-- Andere plots onzichtbaar maken
if BasesFolder then
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        if plot ~= myPlot then
            for _, obj in ipairs(plot:GetDescendants()) do
                pcall(function()
                    if obj:IsA("BasePart") then
                        obj.Transparency = 1
                        obj.CanCollide = false
                        obj.CastShadow = false
                    elseif obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Light") then
                        obj:Destroy()
                    elseif obj:IsA("Sound") then
                        obj.Volume = 0
                    end
                end)
            end
        end
    end
end

-- Algemene Workspace rommel vernietigen
for _, obj in ipairs(workspace:GetChildren()) do
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") then continue end
    if isProtected(obj) then continue end
    pcall(function()
        if obj:IsA("BasePart") and (obj.Size.X > 100 or obj.Size.Z > 100) then
            obj.Transparency = 1
            obj.CastShadow = false
        elseif obj:IsA("Folder") or obj:IsA("Model") or obj:IsA("BasePart") then
            obj:Destroy()
        end
    end)
end

-- Anti-lag voor binnenkomende objecten/spelers
local function stopAnims(character)
    for _, obj in ipairs(character:GetDescendants()) do
        pcall(function()
            if obj:IsA("Animator") then
                for _, track in ipairs(obj:GetPlayingAnimationTracks()) do track:Stop() end
            end
        end)
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer and player.Character then stopAnims(player.Character) end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(c)
        task.wait(1)
        stopAnims(c)
    end)
end)

workspace.ChildAdded:Connect(function(obj)
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") or isProtected(obj) then return end
    task.defer(function()
        pcall(function() obj:Destroy() end)
    end)
end)

