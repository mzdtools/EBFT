local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer
local BasesFolder = workspace:FindFirstChild("Bases")

-- Character tracking tegen respawn-crashes
local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")

LocalPlayer.CharacterAdded:Connect(function(newChar)
    char = newChar
    root = newChar:WaitForChild("HumanoidRootPart")
end)

-- Wachttijd voor trage clients / auto-execute
local LOAD_WAIT = 4
print("⏳ Wachten op laden... (" .. LOAD_WAIT .. "s)")
task.wait(LOAD_WAIT)

BasesFolder = workspace:WaitForChild("Bases", 20)
char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
root = char:WaitForChild("HumanoidRootPart")

-- ==========================================
-- Plot vinden op basis van afstand
-- ==========================================
local myPlot = nil
if BasesFolder and root then
    local minDistance = math.huge
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local ref = plot:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            local dist = (ref.Position - root.Position).Magnitude
            if dist < minDistance then
                minDistance = dist
                myPlot = plot
            end
        end
    end
end

print(myPlot and "✅ Plot gevonden: " .. myPlot.Name or "⚠️ Geen plot gevonden!")

local PROTECTED_KEYWORDS = {"Craft", "Station", "Portal", "Upgrade", "Shop", "Spawn", "Base"}
local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED_KEYWORDS) do
        if name:find(word:lower()) then return true end
    end
    return false
end

-- ==========================================
-- Slimme Schoonmaak Logica (Geen isFloor-check meer!)
-- ==========================================
local function cleanObject(obj, isOwnPlot)
    pcall(function()
        -- 1. Verwijder ALTIJD alle decals, textures en teksten (op jouw base én andere)
        if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SurfaceGui") or obj:IsA("BillboardGui") then
            obj:Destroy()
            
        -- 2. Verwijder alle 3D meshes en brainrot modellen
        elseif obj:IsA("SpecialMesh") or obj:IsA("CharacterMesh") or obj:IsA("Accessory") then
            obj:Destroy()
            
        -- 3. MeshParts onzichtbaar maken om errors te voorkomen
        elseif obj:IsA("MeshPart") then
            obj.Transparency = 1
            obj.CanCollide = false
            obj.CastShadow = false
            
        -- 4. Verwijder neppe NPC's/Beelden, laat echte spelers met rust
        elseif obj:IsA("Humanoid") then
            local parentModel = obj.Parent
            if parentModel and parentModel:IsA("Model") and not Players:GetPlayerFromCharacter(parentModel) then
                parentModel:Destroy()
            end
            
        -- 5. Verwijder alle laggy effecten
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj:Destroy()
            
        -- 6. Geluiden dempen
        elseif obj:IsA("Sound") then
            obj.Volume = 0

        -- 7. Onderdelen / Blokken optimaliseren
        elseif obj:IsA("BasePart") then
            obj.CastShadow = false
            obj.Material = Enum.Material.SmoothPlastic -- Forceer plastic voor FPS
            
            if not isOwnPlot then
                -- Andermans base wordt volledig onzichtbaar en collision-loos
                obj.Transparency = 1
                obj.CanCollide = false
                obj.CanTouch = false
                obj.CanQuery = false
            else
                -- JOUW base: we slopen GEEN onderdelen. Alleen muren hoger dan 15 studs worden verborgen.
                if obj.Size.Y > 15 and not isProtected(obj) then
                    obj.Transparency = 1
                    obj.CanCollide = false
                end
            end
        end
    end)
end

-- ==========================================
-- Bestaande en nieuwe base-troep live cleanen
-- ==========================================
if BasesFolder then
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local isOwnPlot = (plot == myPlot)
        
        -- Direct cleanen bij het laden
        for _, obj in ipairs(plot:GetDescendants()) do
            cleanObject(obj, isOwnPlot)
        end
        
        -- Live bijhouden als er nieuwe troep wordt gebouwd/gespawnd
        plot.DescendantAdded:Connect(function(desc)
            cleanObject(desc, isOwnPlot)
        end)
    end
end

-- ==========================================
-- Workspace & Lobby leegvegen buiten de bases
-- ==========================================
for _, obj in ipairs(Workspace:GetChildren()) do
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") or isProtected(obj) then continue end
    
    pcall(function()
        if obj:IsA("BasePart") then
            -- Grote baseplates alleen onzichtbaar maken zodat je niet valt
            obj.Transparency = 1
            obj.CastShadow = false
            obj.Material = Enum.Material.SmoothPlastic
        end
        for _, desc in ipairs(obj:GetDescendants()) do
            cleanObject(desc, false)
        end
    end)
end

-- ==========================================
-- Lighting & Performance Tweaks
-- ==========================================
pcall(function()
    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
    Lighting.FogEnd = 150 -- Verre objecten stoppen met renderen
    Lighting.FogStart = 100
    Lighting.FogColor = Color3.fromRGB(0, 0, 0)
    Lighting.OutdoorAmbient = Color3.fromRGB(100, 100, 100)
    Lighting.Ambient = Color3.fromRGB(80, 80, 80)
end)

for _, e in ipairs(Lighting:GetChildren()) do
    pcall(function() if e:IsA("PostEffect") then e.Enabled = false end end)
end

pcall(function()
    Workspace.Terrain.WaterWaveSize = 0
    Workspace.Terrain.WaterWaveSpeed = 0
    Workspace.Terrain.Decoration = false
end)

-- Animaties van anderen stoppen
local function stopAnimations(character)
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("Animator") then
            for _, track in ipairs(obj:GetPlayingAnimationTracks()) do pcall(function() track:Stop() end) end
        end
    end
end

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer and player.Character then stopAnimations(player.Character) end
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(otherChar)
        task.wait(1)
        stopAnimations(otherChar)
    end)
end)

-- Live Workspace Tracker
Workspace.ChildAdded:Connect(function(obj)
    if obj == char or obj == BasesFolder or obj:IsA("Terrain") or obj:IsA("Camera") or isProtected(obj) then return end
    task.defer(function()
        pcall(function() 
            if obj:IsA("BasePart") then
                if obj.Size.X > 200 or obj.Size.Z > 200 then
                    obj.Transparency = 1
                    obj.Material = Enum.Material.SmoothPlastic
                else
                    obj:Destroy()
                end
            else
                for _, desc in ipairs(obj:GetDescendants()) do cleanObject(desc, false) end
            end
        end)
    end)
end)

print("🚀 TOTAALSCRIPT ACTIEF: Decals & Brainrot weg op álle bases, vloer staat als een huis!")
