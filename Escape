local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- CONFIGURATIE: Rendering Switch
-- ==========================================
local DISABLE_3D_RENDERING = true -- Zet op 'true' voor maximale FPS, 'false' om alles te zien

-- Schakel rendering direct uit indien ingesteld
if DISABLE_3D_RENDERING then
    RunService:Set3dRenderingEnabled(false)
    print("⚡ 3D Rendering is UITgeschakeld voor maximale performance!")
end

-- ==========================================
-- Oude setup (Char/BasesFolder)
-- ==========================================
local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local root = char:WaitForChild("HumanoidRootPart")

LocalPlayer.CharacterAdded:Connect(function(newChar)
    char = newChar
    root = newChar:WaitForChild("HumanoidRootPart")
end)

local LOAD_WAIT = 4 
task.wait(LOAD_WAIT)

local BasesFolder = Workspace:WaitForChild("Bases", 20)
char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
root = char:WaitForChild("HumanoidRootPart")

-- Plot detectie
local myPlot = nil
if BasesFolder and root then
    local minDistance = math.huge
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local ref = plot:FindFirstChildWhichIsA("BasePart", true)
        if ref then
            local dist = (ref.Position - root.Position).Magnitude
            if dist < minDistance then
                minDistance = dist
                myPlot = plot
            end
        end
    end
end

-- Protected keywords
local PROTECTED_KEYWORDS = {"Craft", "Station", "Portal", "Upgrade", "Shop", "Spawn", "Base"}
local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED_KEYWORDS) do
        if name:find(word:lower()) then return true end
    end
    return false
end

-- ==========================================
-- Optimalisaties (Lighting/Terrain)
-- ==========================================
pcall(function()
    Lighting.Technology = Enum.Technology.Compatibility
    Lighting.GlobalShadows = false
    Lighting.Brightness = 2
    Lighting.ClockTime = 14
end)

pcall(function()
    Workspace.Terrain.WaterWaveSize = 0
    Workspace.Terrain.Decoration = false
end)

-- ==========================================
-- Stripping Logica
-- ==========================================
local function cleanObject(obj, isOwnPlot)
    pcall(function()
        if isProtected(obj) then return end
        
        -- Verwijder alles wat zwaar is
        if obj:IsA("Decal") or obj:IsA("Texture") or obj:IsA("SpecialMesh") or obj:IsA("CharacterMesh") or obj:IsA("Accessory") or 
           obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
            obj:Destroy()
        elseif obj:IsA("BasePart") then
            obj.CastShadow = false
            obj.Material = Enum.Material.SmoothPlastic
            if not isOwnPlot then
                obj.Transparency = 1
                obj.CanCollide = false
            end
        end
    end)
end

-- Run cleaners
if BasesFolder then
    for _, plot in ipairs(BasesFolder:GetChildren()) do
        local isOwn = (plot == myPlot)
        for _, obj in ipairs(plot:GetDescendants()) do cleanObject(obj, isOwn) end
        plot.DescendantAdded:Connect(function(d) cleanObject(d, isOwn) end)
    end
end

-- ==========================================
-- Animaties stoppen (CPU winst)
-- ==========================================
local function stopAnims(c)
    for _, a in ipairs(c:GetDescendants()) do
        if a:IsA("Animator") then
            for _, t in ipairs(a:GetPlayingAnimationTracks()) do t:Stop() end
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer and p.Character then stopAnims(p.Character) end
end
Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(stopAnims) end)

print("🚀 Ultimate Performance Modus Actief: Rendering=" .. (DISABLE_3D_RENDERING and "UIT" or "AAN"))
