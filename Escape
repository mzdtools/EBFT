-- ================================================

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Lijst met woorden die aangeven dat een object FUNCTIONEEL is (NIET verwijderen)
local PROTECTED_KEYWORDS = {"Craft", "Station", "Portal", "Upgrade", "Shop", "Spawn", "Base"}

local function isProtected(obj)
    local name = obj.Name:lower()
    for _, word in ipairs(PROTECTED_KEYWORDS) do
        if name:find(word:lower()) then return true end
    end
    return false
end

-- Vind jouw plot
local myPlotFolder = workspace:FindFirstChild("Bases") and workspace.Bases:FindFirstChild(LocalPlayer.Name) -- Pas dit aan als je plot ID-gebaseerd is

print("🚀 Semi-Agressieve strip gestart...")

for _, obj in ipairs(workspace:GetChildren()) do
    -- 1. Bescherm je eigen karakter
    if obj == LocalPlayer.Character then continue end
    
    -- 2. Bescherm jouw plot
    if obj == myPlotFolder then continue end
    
    -- 3. Bescherm functionele objecten in de map
    if isProtected(obj) then continue end
    
    -- 4. Bescherm Terrain
    if obj:IsA("Terrain") then continue end
    
    -- 5. Vernietig de rest (decoratie, bomen, andere plots)
    pcall(function()
        if obj:IsA("Folder") or obj:IsA("Model") or obj:IsA("BasePart") then
            -- Als het een map met andere plots is, wis alleen plots die NIET de jouwe zijn
            if obj.Name == "Bases" then
                for _, otherPlot in ipairs(obj:GetChildren()) do
                    if otherPlot ~= myPlotFolder then otherPlot:Destroy() end
                end
            else
                obj:Destroy()
            end
        end
    end)
end

print("✅ Map gestript. Functionaliteit behouden.")
