-- ==========================================
-- DATA HELPERS & STRATEGIE LOGICA
-- ==========================================
local function getData()
    return ClientGlobals and ClientGlobals.PlayerData and ClientGlobals.PlayerData.Data
end

local function getAbsoluteRolls()
    local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
    if leaderstats then
        local r = leaderstats:FindFirstChild("Rolls") or leaderstats:FindFirstChild("Total Rolls")
        if r then return r.Value end
    end
    local data = getData()
    if data then return data.Rolls or data.TotalRolls or data.RollCount or _G.MzDRolls or 0 end
    return _G.MzDRolls or 0
end

local function countCollectedRarity(targetRarity)
    local data = getData()
    if not data or not data.CollectedBrainrots or not BrainrotModule then return 0 end
    local count = 0
    for _, brainrots in pairs(data.CollectedBrainrots) do
        for name, _ in pairs(brainrots) do
            if BrainrotModule.BrainrotRarities and BrainrotModule.BrainrotRarities[name] == targetRarity then
                count += 1
            end
        end
    end
    return count
end

local function isDice777EventActive()
    if not ClientGlobals or not ClientGlobals.ActiveEvents or not ClientGlobals.ActiveEvents.Data then return false end
    local now = workspace:GetServerTimeNow()
    local endTime = ClientGlobals.ActiveEvents.Data["Dice777Event"]
    if type(endTime) == "number" and endTime > now then
        return true
    end
    return false
end

local globalMegaCount = 0

local function updateInventoryAndUpgrades()
    local data = getData()
    local counts = {Normal = 0, Fire = 0, Gold = 0, Rainbow = 0, MegaRainbow = 0}
    
    if data and data.Inventory then
        for _, item in pairs(data.Inventory) do
            if item.sub and item.sub.diceType and counts[item.sub.diceType] ~= nil then
                local amt = type(item.sub.amount) == "number" and item.sub.amount or 1
                counts[item.sub.diceType] = counts[item.sub.diceType] + amt
            end
        end
    end

    globalMegaCount = counts.MegaRainbow

    normalLbl.Text  = "Normal: "  .. counts.Normal
    fireLbl.Text    = "Fire: "    .. counts.Fire
    goldLbl.Text    = "Gold: "    .. counts.Gold
    rainbowLbl.Text = "Rainbow: " .. counts.Rainbow
    megaLbl.Text    = "MegaRainbow: " .. counts.MegaRainbow
    megaLbl.TextColor3 = counts.MegaRainbow > 0 and Color3.fromRGB(255,100,255) or Color3.fromRGB(80,80,80)

    -- Upgrades
    if data and data.RNGUpgrades and RNGConfig and RNGConfig.Upgrades then
        local UPGRADES = {"RollSpeed","Luck","InfinityLuck","EternalLuck","TraitLuck"}
        local notDone = {}
        for _, name in ipairs(UPGRADES) do
            local lvl = data.RNGUpgrades[name] or 0
            local cfg = RNGConfig.Upgrades[name]
            if cfg and lvl < cfg.MaxLevel then table.insert(notDone, name) end
        end
        if #notDone == 0 then
            upgradeLbl.Text = "UPGRADES: ✅ ALL MAX"
            upgradeLbl.TextColor3 = Color3.fromRGB(80, 255, 80)
        else
            upgradeLbl.Text = "🔄 " .. table.concat(notDone, ", ")
            upgradeLbl.TextColor3 = Color3.fromRGB(255, 195, 60)
        end
    end
end

