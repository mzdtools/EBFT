local UPGRADES  = {"RollSpeed","Luck","InfinityLuck","EternalLuck","TraitLuck"}

task.spawn(function()
    while gui and gui.Parent do
        pcall(function()
            local e = tick() - startTime
            timeLbl.Text  = cf(string.format("%02d:%02d:%02d",
                math.floor(e/3600), math.floor((e%3600)/60), math.floor(e%60)))
            rollsLbl.Text = cf("Rolls: " .. (_G.MzDRolls or 0))

            normalLbl.Text  = cf("Normal: "  .. getDiceCount("Normal"))
            fireLbl.Text    = cf("Fire: "    .. getDiceCount("Fire"))
            goldLbl.Text    = cf("Gold: "    .. getDiceCount("Gold"))
            rainbowLbl.Text = cf("Rainbow: " .. getDiceCount("Rainbow"))

            local mc = getDiceCount("MegaRainbow")
            megaLbl.Text       = cf("MegaRainbow: " .. mc)
            megaLbl.TextColor3 = mc > 0 and RED or DIMMED

            infLbl.Text = cf("Infinity: " .. countCollectedRarity("Infinity"))
            etLbl.Text  = cf("Eternal: "  .. countCollectedRarity("Eternal"))

            local allMax = true
            local notDone = {}
            for _, name in ipairs(UPGRADES) do
                if not isUpgradeMaxed(name) then allMax = false; table.insert(notDone, name) end
            end
            if allMax then
                upgradeLbl.Text       = cf("Upgrades: ALL MAX")
                upgradeLbl.TextColor3 = WHITE
            else
                upgradeLbl.Text       = cf("Upgrading: " .. table.concat(notDone, ", "))
                upgradeLbl.TextColor3 = RED
            end

            local events = getActiveEvents()
            eventLbl.Text       = cf("Events: " .. events)
            eventLbl.TextColor3 = events ~= "geen" and RED or WHITE
        end)
        task.wait(0.5)
    end
end)

