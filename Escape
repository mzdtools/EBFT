            local elapsed = tick() - startTime
            timeLbl.Text  = "⏱ " .. string.format("%02d:%02d:%02d",
                math.floor(elapsed/3600), math.floor((elapsed%3600)/60), math.floor(elapsed%60))
            rollsLbl.Text = "🎲 Rolls: " .. (_G.MzDSessionRolls or 0)

