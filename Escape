-- =========================================================================
-- KLEUREN & RICHTEXT HELPER
-- Eerste ASCII letter of cijfer → lichtblauw, rest → wit
-- Werkt correct met emoji (multi-byte bytes worden overgeslagen)
-- =========================================================================
local WHITE  = Color3.new(1, 1, 1)
local RED    = Color3.fromRGB(220, 50, 50)
local DIMMED = Color3.fromRGB(90, 90, 90)
local DARK   = Color3.fromRGB(30, 30, 30)
local LBLUE  = "rgb(100,200,255)"

local function cf(text)
    if not text or text == "" then return text end
    for i = 1, #text do
        local b = text:byte(i)
        if (b >= 65 and b <= 90) or (b >= 97 and b <= 122) or (b >= 48 and b <= 57) then
            return text:sub(1, i-1)
                .. '<font color="' .. LBLUE .. '">' .. text:sub(i, i) .. '</font>'
                .. text:sub(i+1)
        end
    end
    return text
end

